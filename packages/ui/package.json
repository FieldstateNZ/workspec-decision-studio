{
  "name": "@workspec/decision-ui",
  "version": "0.1.0-alpha.0",
  "description": "Host-agnostic React views for WorkSpec Decision Studio (standalone lib + module-federation remote).",
  "keywords": [
    "react",
    "module-federation",
    "architecture-decision-records",
    "ui"
  ],
  "homepage": "https://github.com/FieldstateNZ/workspec-decision-studio#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FieldstateNZ/workspec-decision-studio.git",
    "directory": "packages/ui"
  },
  "license": "Apache-2.0",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "@workspec/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup && tailwindcss --input src/index.css --output dist/styles.css --minify",
    "build:mf": "vite build --config vite.config.mf.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "dependencies": {
    "@workspec/decision-engine": "workspace:*",
    "@workspec/decision-schema": "workspace:*",
    "@workspec/design": "0.1.0-alpha.0"
  },
  "devDependencies": {
    "@module-federation/vite": "^1.16.12",
    "@tailwindcss/cli": "^4.1.14",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.62.7",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.1.14",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vite": "^7.0.0",
    "vitest": "^3.2.4"
  }
}
