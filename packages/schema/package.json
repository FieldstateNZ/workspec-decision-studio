{
  "name": "@workspec/decision-schema",
  "version": "0.1.0-alpha.0",
  "description": "Zod source of truth for WorkSpec Decision Studio artifacts — TS types, runtime validation, and generated JSON Schema.",
  "keywords": [
    "zod",
    "json-schema",
    "yaml",
    "architecture-decision-records",
    "schema"
  ],
  "homepage": "https://github.com/FieldstateNZ/workspec-decision-studio#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FieldstateNZ/workspec-decision-studio.git",
    "directory": "packages/schema"
  },
  "license": "Apache-2.0",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "@workspec/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "gen:schema": "tsx scripts/gen-json-schema.ts"
  },
  "dependencies": {
    "yaml": "^2.6.0",
    "zod": "^3.24.0",
    "zod-to-json-schema": "^3.24.0"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
