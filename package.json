{
  "name": "workspec-decision-studio",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Costed architecture decisions as reviewable YAML artifacts. Free, standalone, git-native.",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @workspec/decision-studio dev",
    "test": "vitest run",
    "test:pkgs": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "gen:schema": "pnpm --filter @workspec/decision-schema gen:schema",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^3.2.4"
  }
}
