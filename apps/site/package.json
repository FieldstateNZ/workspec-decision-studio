{
  "name": "@workspec/site",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Product site + in-browser demo for WorkSpec Decision Studio. Consumes the PUBLISHED @workspec/* packages from npm — if the site builds, the packages work for outside consumers.",
